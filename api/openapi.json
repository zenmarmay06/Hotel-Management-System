{
  "openapi": "3.0.0",
  "info": {
    "title": "hotel-task API",
    "version": "1.0.0",
    "description": "API documentation for Hotel Management System"
  },
  "servers": [
    {
      "url": "http://localhost/Hotel-Management-System-main/api"
    }
  ],
  "paths": {
    "/tasks": {
      "get": {
        "summary": "Get all tasks",
        "responses": {
          "200": {
            "description": "List of tasks",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Task" } }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new task",
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TaskCreate" } }
          }
        },
        "responses": { "200": { "description": "Task created" } }
      }
    },
    "/tasks/{id}": {
      "put": {
        "summary": "Update task",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/TaskUpdate" } }
          }
        },
        "responses": { "200": { "description": "Task updated" } }
      },
      "delete": {
        "summary": "Delete task",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Task deleted" } }
      }
    },
    "/room": {
      "get": {
        "summary": "Get rooms by status",
        "parameters": [
          { "name": "status", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "List of rooms" } }
      }
    },
    "/staff": {
      "get": {
        "summary": "Get staff by work type",
        "parameters": [
          { "name": "work", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "List of staff" } }
      }
    },
    "/room/{roomno}": {
      "put": {
        "summary": "Update room status",
        "parameters": [
          { "name": "roomno", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string" },
                  "assignedTo": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Room status updated" } }
      }
    }
  },
  "components": {
    "schemas": {
      "Task": {
        "type": "object",
        "properties": {
          "Id": { "type": "integer" },
          "RoomNo": { "type": "string" },
          "Priority": { "type": "string" },
          "AssignedTo": { "type": "string" },
          "DueDate": { "type": "string", "format": "date" },
          "Status": { "type": "string" },
          "Note": { "type": "string" }
        }
      },
      "TaskCreate": {
        "type": "object",
        "properties": {
          "roomNo": { "type": "string" },
          "priority": { "type": "string" },
          "assignedTo": { "type": "string" },
          "dueDate": { "type": "string", "format": "date" },
          "status": { "type": "string" },
          "note": { "type": "string" }
        }
      },
      "TaskUpdate": {
        "type": "object",
        "properties": {
          "roomNo": { "type": "string" },
          "priority": { "type": "string" },
          "assignedTo": { "type": "string" },
          "dueDate": { "type": "string", "format": "date" },
          "status": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}